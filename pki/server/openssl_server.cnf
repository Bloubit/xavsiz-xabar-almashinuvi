[ req ]
default_bits       = 4096
prompt             = no
default_md         = sha256
distinguished_name = dn
req_extensions     = req_ext

[ dn ]
C  = UZ
ST = Tashkent
L  = Tashkent
O  = Secure TLS Project
OU = Server
CN = Secure Flask Server

[ req_ext ]
subjectAltName = @alt_names
extendedKeyUsage = serverAuth

[ alt_names ]
DNS.1 = localhost
IP.1  = 127.0.0.1
IP.2  = 10.42.40.16